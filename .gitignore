# === Force Cisco as the language for all network configs ===
*.conf linguist-language=Cisco

# === Packet Tracer files count as their own language ===
*.pkt linguist-language=Packet Tracer

# === Treat the .pkt as vendored (not user code) ===
# We don't want it polluting the stats
*.pkt linguist-vendored=false
*.pkt linguist-generated=false

# === Docs, diagrams, READMEs — they're docs, not code ===
*.md linguist-documentation
docs/* linguist-documentation
diagrams/* linguist-documentation
LICENSE linguist-documentation

# === Binary assets — exclude from language stats ===
*.pptx linguist-vendored
*.pdf linguist-vendored
